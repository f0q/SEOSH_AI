# ──────────────────────────────────────────────────
# SEOSH.AI — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────

# ─── Database ────────────────────────────────────
DATABASE_URL=postgresql://seosh:seosh_dev_pass@localhost:5432/seosh_ai

# ─── Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Object Storage (MinIO / S3) ─────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=seosh-media

# ─── Auth ────────────────────────────────────────
AUTH_SECRET=change-me-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# ─── AI Provider (superadmin configurable) ───────
# Default provider: openrouter | openai | anthropic | ollama
AI_DEFAULT_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-key
OLLAMA_BASE_URL=http://localhost:11434

# Default models (superadmin configurable)
AI_MODEL_CATEGORIZE=google/gemini-2.0-flash-001
AI_MODEL_CONTENT=google/gemini-2.0-flash-001
AI_MODEL_ANALYZE=google/gemini-2.0-flash-001

# ─── SEO Tools (modular — enable/disable) ────────
TEXTRU_API_KEY=your-textru-api-key
TEXTRU_ENABLED=true
PIXELTOOLS_API_KEY=your-pixeltools-api-key
PIXELTOOLS_ENABLED=true

# ─── Analytics APIs ──────────────────────────────
YANDEX_METRIKA_TOKEN=
YANDEX_WEBMASTER_TOKEN=
GOOGLE_SEARCH_CONSOLE_KEY=

# ─── Telegram Bot ────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# ─── App ─────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SEOSH.AI
