# ─────────────────────────────────────────────────────────
# SEOSH.AI — Production Environment Variables
# Copy to .env.production and fill in your values
# ─────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://seosh.aijam.pro
NEXT_PUBLIC_APP_NAME=SEOSH.AI

# ─── Database (internal Docker network) ──────────
POSTGRES_USER=seosh
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=seosh_ai
DATABASE_URL=postgresql://seosh:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/seosh_ai

# ─── Redis ───────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379

# ─── MinIO (S3 storage) ─────────────────────────
MINIO_ROOT_USER=seosh_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=seosh_minio
S3_SECRET_KEY=CHANGE_ME_STRONG_MINIO_PASSWORD
S3_BUCKET=seosh-media

# ─── Auth ────────────────────────────────────────
BETTER_AUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
BETTER_AUTH_URL=https://seosh.aijam.pro

# ─── AI Provider ─────────────────────────────────
AI_DEFAULT_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
AI_MODEL_CATEGORIZE=google/gemini-2.0-flash-001
AI_MODEL_CONTENT=google/gemini-2.0-flash-001
AI_MODEL_ANALYZE=google/gemini-2.0-flash-001

# ─── SEO Tools ───────────────────────────────────
TEXTRU_API_KEY=
TEXTRU_ENABLED=false
PIXELTOOLS_API_KEY=
PIXELTOOLS_ENABLED=false

# ─── Encryption ──────────────────────────────────
ENCRYPTION_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_16
ADMIN_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_16

# ─── SMTP (for email invites) ────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@seosh.aijam.pro
